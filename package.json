{
	"name": "obsidian-postgres-browser",
	"version": "1.0.2",
	"description": "PostgreSQL browser sidebar plugin for Obsidian",
	"license": "MIT",
	"main": "main.js",
	"scripts": {
		"dev": "node esbuild.config.mjs",
		"build": "tsc -noEmit -skipLibCheck && node esbuild.config.mjs production",
		"deploy": "npm run build && node copy-to-vault.mjs",
		"lint": "eslint src/"
	},
	"dependencies": {
		"postgres": "^3.4.7"
	},
	"devDependencies": {
		"@types/node": "^16.11.6",
		"builtin-modules": "^3.3.0",
		"esbuild": "^0.25.0",
		"eslint": "^10.0.3",
		"eslint-plugin-obsidianmd": "^0.1.9",
		"obsidian": "latest",
		"tslib": "2.4.0",
		"typescript": "~5.6.0"
	}
}
