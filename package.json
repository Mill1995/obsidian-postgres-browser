{
	"name": "obsidian-postgres-browser",
	"version": "1.0.0",
	"description": "PostgreSQL browser sidebar plugin for Obsidian",
	"main": "main.js",
	"scripts": {
		"dev": "node esbuild.config.mjs",
		"build": "tsc -noEmit -skipLibCheck && node esbuild.config.mjs production",
		"deploy": "npm run build && node copy-to-vault.mjs"
	},
	"dependencies": {
		"postgres": "^3.4.7"
	},
	"devDependencies": {
		"@types/node": "^16.11.6",
		"builtin-modules": "^3.3.0",
		"esbuild": "0.17.3",
		"obsidian": "latest",
		"tslib": "2.4.0",
		"typescript": "4.7.4"
	}
}
